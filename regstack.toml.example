# regstack.toml — example configuration
#
# Generated by `regstack init`. Edit by hand or re-run the wizard.
# Secrets (jwt_secret, smtp password, twilio token, etc.) belong in
# regstack.secrets.env, never here.

app_name = "MyApp"
base_url = "http://localhost:8000"
# cookie_domain = "myapp.example"
behind_proxy = false

mongodb_database = "myapp"
user_collection = "users"
pending_collection = "pending_registrations"

jwt_algorithm = "HS256"
jwt_ttl_seconds = 7200
transport = "bearer"

require_verification = false        # M1: no verification flow yet, leave false
allow_registration = true
enable_password_reset = true
enable_account_deletion = true
enable_admin_router = false
enable_ui_router = false
enable_sms_2fa = false
enable_oauth = false                # OAuth providers are a future task

rate_limit_disabled = false
login_max_per_minute = 5
login_max_per_hour = 20

[email]
backend = "console"                 # console | smtp | ses
from_address = "noreply@myapp.example"
from_name = "MyApp"
# For smtp:
# smtp_host = "smtp.example.com"
# smtp_port = 587
# smtp_starttls = true
# smtp_username = "myapp"
# For ses:
# ses_region = "eu-west-1"

[sms]
backend = "null"                    # null | sns | twilio
# from_number = "+15555550100"
# sns_region = "eu-west-1"
# twilio_account_sid = ""
